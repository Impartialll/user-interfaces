<Window x:Class="INDZ.SlidersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Повзунки" Height="300" Width="300" WindowStyle="ToolWindow">
    <StackPanel x:Name="slContainer" Margin="20" Slider.ValueChanged="SlContainer_ValueChanged">
        <Slider x:Name="sl1" Tag="1" Margin="2" Maximum="100"/>
        <Slider x:Name="sl2" Tag="2" Margin="2" Maximum="100"/>
        <Slider x:Name="sl3" Tag="3" Margin="2" Maximum="100"/>
        <Slider x:Name="sl4" Tag="4" Margin="2" Maximum="100"/>
        <Slider x:Name="sl5" Tag="5" Margin="2" Maximum="100"/>
        <Slider x:Name="sl6" Tag="6" Margin="2" Maximum="100"/>
        <Slider x:Name="sl7" Tag="7" Margin="2" Maximum="100"/>
    </StackPanel>
</Window>