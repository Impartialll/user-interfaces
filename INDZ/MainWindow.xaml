<Window x:Class="INDZ.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Головне вікно" Height="250" Width="350"
        ResizeMode="CanMinimize" 
        WindowStartupLocation="CenterScreen">

    <Canvas>
        <Button Content="Підкинути монету" 
                Canvas.Left="100" Canvas.Top="40" 
                Width="150" Height="35" 
                Click="BtnOpenDialog_Click"/>

        <TextBlock x:Name="tbTotalTosses" 
                   Text="Сумарне число підкидань = 0" 
                   Canvas.Left="40" Canvas.Top="100" 
                   FontSize="14" FontWeight="SemiBold"/>

        <TextBlock x:Name="tbHeadsPercent" 
                   Text="Відсоток орлів = 0%" 
                   Canvas.Left="40" Canvas.Top="140" 
                   FontSize="14" FontWeight="SemiBold"/>
    </Canvas>
</Window>