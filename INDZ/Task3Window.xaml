<Window x:Class="INDZ.Task3Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завдання 3" Height="400" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="Command">
                <MenuItem Header="Clear" Click="MenuClear_Click"/>
                <MenuItem Header="Exit" Click="MenuExit_Click"/>
            </MenuItem>
        </Menu>
        <Canvas x:Name="MainCanvas" Grid.Row="1" Background="White" AllowDrop="True" Drop="Canvas_Drop"/>
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Content="New" Grid.Column="0" Margin="5" Click="BtnNew_Click"/>
            <Button Content="Trash" Grid.Column="1" Margin="5" Click="BtnTrash_Click" AllowDrop="True" Drop="Trash_Drop"/>
        </Grid>
    </Grid>
</Window>