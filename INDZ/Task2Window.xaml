<Window x:Class="INDZ.Task2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завдання 2" Height="300" Width="300">
    <Grid>
        <StackPanel x:Name="pbContainer" Margin="20" PreviewMouseLeftButtonDown="PbContainer_Click" Background="Transparent">
            <ProgressBar x:Name="pb1" Tag="1" Height="15" Margin="2" Maximum="100"/>
            <ProgressBar x:Name="pb2" Tag="2" Height="15" Margin="2" Maximum="100"/>
            <ProgressBar x:Name="pb3" Tag="3" Height="15" Margin="2" Maximum="100"/>
            <ProgressBar x:Name="pb4" Tag="4" Height="15" Margin="2" Maximum="100"/>
            <ProgressBar x:Name="pb5" Tag="5" Height="15" Margin="2" Maximum="100"/>
            <ProgressBar x:Name="pb6" Tag="6" Height="15" Margin="2" Maximum="100"/>
            <ProgressBar x:Name="pb7" Tag="7" Height="15" Margin="2" Maximum="100"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10">
            <Button Content="Show" Width="80" Margin="5" Click="BtnShow_Click"/>
            <Button Content="Default" Width="80" Margin="5" Click="BtnDefault_Click"/>
        </StackPanel>
    </Grid>
</Window>