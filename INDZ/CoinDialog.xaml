<Window x:Class="INDZ.CoinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Налаштування" Height="150" Width="300" ResizeMode="NoResize" WindowStyle="ToolWindow" Loaded="Window_Loaded">
    <Grid Margin="10">
        <TextBox x:Name="txtTosses" Height="25" VerticalAlignment="Top"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="ОК" Width="70" Margin="5" IsDefault="True" Click="BtnOk_Click"/>
            <Button Content="Застосувати" Width="80" Margin="5" Click="BtnApply_Click"/>
            <Button Content="Відміна" Width="70" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>